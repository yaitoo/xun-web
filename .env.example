# xun-web local + deploy configuration
# ─────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` and edit. The Makefile auto-loads `.env` for
# every target that runs the app (dev, run, build-dist).
#
# Rules:
#   - `.env` is git-ignored; never commit secrets into it.
#   - Lines starting with `#` and blank lines are ignored.
#   - `export FOO=bar` and bare `FOO=bar` both work.
#   - Values may be quoted with " or ' (quotes are stripped).
#
# Naming convention: every var maps to a dotted key in cmd/app/app.yml.
# The prefix is `APP_` and dots become underscores, so:
#     APP_SESSION_SECRET       → session.secret
#     APP_DB_DSN               → db.dsn
#     APP_HTTP                 → http
#     APP_HTTPS_ADDR           → https.addr
#     APP_HTTPS_ENABLED        → https.enabled
#     APP_HTTPS_CERT_FILE      → https.cert_file
#     APP_HTTPS_KEY_FILE       → https.key_file
# Same mapping is used by the Ansible deploy template at
# deploy/playbooks/roles/app/templates/app.yml.j2 (via
# `lookup('env', 'APP_*')`), so the same .env works locally and on
# the deploy host.
#
# Anything in this file is OVERRIDDEN by an already-set shell env var.
# Useful for one-off overrides:
#     make dev APP_SESSION_SECRET=hunter2
# ─────────────────────────────────────────────────────────────────────────

# ── Server bind addresses ────────────────────────────────────────────────
# APP_HTTP=":8080"


# ── HTTPS (only used when APP_HTTPS_ENABLED=true) ────────────────────────
# APP_HTTPS_ENABLED=false
# APP_HTTPS_ADDR=":8443"
# APP_HTTPS_CERT_FILE=./certs/server.crt
# APP_HTTPS_KEY_FILE=./certs/server.key

# ── Database ─────────────────────────────────────────────────────────────
# APP_DB_DSN=./app.db

# ── Session ──────────────────────────────────────────────────────────────
# Generate a strong secret, e.g. `openssl rand -base64 48`. REQUIRED in
# production; the dev fallback in cmd/app/app.yml is `change-me-in-production`
# which is rejected by session middleware at first use.
APP_SESSION_SECRET=change-me-in-production
# APP_SESSION_MAX_AGE=604800
