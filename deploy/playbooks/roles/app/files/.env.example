# Example environment file for the xun-web deploy role.
#
# Usage (from the repo root, before running ansible):
#   set -a; . deploy/playbooks/roles/app/files/.env.example; set +a
#   ansible-playbook deploy/playbooks/app.yml
#
# All variables are optional EXCEPT APP_SESSION_SECRET — a strong
# random value is required for production. Generate one with:
#   openssl rand -base64 48

# --- Network listeners -----------------------------------------------------
# APP_HTTP=":80"
# APP_HTTPS_ADDR=":443"

# --- HTTPS (only used when APP_HTTPS_ENABLED=true) -------------------------
# APP_HTTPS_ENABLED=false
# APP_HTTPS_CERT_FILE=/etc/ssl/certs/xun-web.crt
# APP_HTTPS_KEY_FILE=/etc/ssl/private/xun-web.key

# --- Database -------------------------------------------------------------
# APP_DB_DSN=./app.db

# --- Session --------------------------------------------------------------
# Generate a strong secret, e.g. `openssl rand -base64 48`. REQUIRED.
APP_SESSION_SECRET=change-me-in-production
# APP_SESSION_MAX_AGE=604800
