# RustFS Configuration
# S3 Compatible Storage Service

# Server settings
host: "0.0.0.0"
port: {{ rustfs_port | default(9000) }}

# Data directory
data_dir: "/var/lib/rustfs"

# Access credentials (change these in production!)
access_key: "{{ rustfs_access_key | default('@Yaitoo2026@AK') }}"
secret_key: "{{ rustfs_secret_key | default('@Yaitoo2026@SK') }}"

# Bucket settings
max_bucket_size: "{{ rustfs_max_bucket_size | default(10737418240) }}"  # 10GB default

# Logging
log_level: "{{ rustfs_log_level | default('info') }}"
