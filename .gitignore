# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# Database
*.db
*.db-wal
*.db-shm

# env file
.env

# node_modules
node_modules/

# Build output — ./bin/ holds the locally-compiled Go binary, ./dist/
# holds the distribution artefacts produced by `make build-dist`. Kept
# separate so the two never overwrite each other. A bare `app` at the
# repo root is a stray produced by `go build` without `-o bin/app` and
# should also not be tracked.
/app
/bin/
/dist/

# Standalone Tailwind + esbuild binaries and generated bundles
# (regenerated by `make build-ui`)
/cmd/app/app/public/assets/app.css
/cmd/app/app/public/assets/app.min.js

# Editor/IDE
# .idea/
# .vscode/
